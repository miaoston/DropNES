{
  "manifest_version": 3,
  "name": "DropNES",
  "version": "0.0.1",
  "description": "A Pro-Level NES Emulator Platform. Bring Your Own Game.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Open DropNES"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
